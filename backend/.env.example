APP_NAME=Rentora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Tegucigalpa
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=rentora
DB_USERNAME=rentora_user
DB_PASSWORD=rentora_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=mailgun
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@rentora.com"
MAIL_FROM_NAME="${APP_NAME}"

# Storage (S3 for prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Feature Flags
FEATURE_KYC_ENABLED=false
FEATURE_PAYMENTS_ENABLED=false

# Laravel Telescope (Local only)
TELESCOPE_ENABLED=true
